# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DB_NAME=moneta_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/moneta_db
Database_Url=postgresql://postgres:postgres@db:5432/moneta_db

# For local development (without Docker), use localhost instead of db:
# DB_HOST=localhost
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moneta_db
# Database_Url=postgresql://postgres:postgres@localhost:5432/moneta_db

# Server Configuration
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Email Configuration (Gmail SMTP)
EMAIL_HOST_USER=your-gmail-username@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True
EMAIL_PORT=587

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication
# 2. Generate an app-specific password
# 3. Use the app password instead of your regular password